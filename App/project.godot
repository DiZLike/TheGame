; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="TheGame"
run/main_scene="uid://bywi2eo8g1grj"
config/use_custom_user_dir=true
config/custom_user_dir_name="DiZlike/Glitchvania"
config/features=PackedStringArray("4.6", "Mobile")
boot_splash/show_image=false
boot_splash/use_filter=false
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://cvph1shkc3og5"

[autoload]

WeaponManager="*uid://cg1q8mrvoc8xd"
DialogueLoader="*uid://dawjopqo4gpvm"
AudioManager="*uid://bougi501l3reb"
ScoreManager="*uid://b8cwsirgsb3f2"
InventoryManager="*uid://cgfl38e2rquta"
BarrierSourceManager="*uid://cgvw6qw7f4ict"
GameManager="*uid://clu8nd0tgm2c5"
InputManager="*uid://bjgscygusc7jr"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="TheGame"

